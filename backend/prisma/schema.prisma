generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pgrouting]
}

enum UserRole {
  ADMIN
  USER
  SHELTER_OFFICER
}

enum HazardLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RoadType {
  NATIONAL
  PROVINCIAL
  REGIONAL
  LOCAL
}

enum RoadCondition {
  GOOD
  MODERATE
  POOR
  DAMAGED
}

enum RoadVulnerability {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ShelterCondition {
  GOOD
  MODERATE
  NEEDS_REPAIR
  DAMAGED
}

enum ShelterStatus {
  ACTIVE
  STANDBY
  UNAVAILABLE
}

enum RouteType {
  PRIMARY
  ALTERNATIVE
}

enum BpbdRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum EvacueeStatus {
  ACTIVE
  RELOCATED
  RETURNED_HOME
}

enum EvacueeGender {
  MALE
  FEMALE
}

model User {
  id                 Int                @id @default(autoincrement())
  email              String             @unique
  password           String
  name               String
  role               UserRole           @default(USER)
  pushSubscriptions  PushSubscription[]
  managedShelters    Shelter[]
  registeredEvacuees Evacuee[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Earthquake {
  id          Int       @id @default(autoincrement())
  bmkgId      String?   @unique
  magnitude   Float
  depth       Float
  lat         Float
  lon         Float
  geom        Unsupported("geometry(Point, 4326)")?
  location    String
  region      String
  time        DateTime
  timestamp   DateTime  @default(now())
  isLatest    Boolean   @default(false)
  dirasakan   String?
  potential   String?
  shakemapUrl String?
}

model HazardZone {
  id          Int        @id @default(autoincrement())
  name        String
  level       HazardLevel
  geometry    Json
  geom        Unsupported("geometry(Polygon, 4326)")?
  description String?
  area        Float?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Shelter {
  id               Int              @id @default(autoincrement())
  name             String
  capacity         Int
  currentOccupancy Int              @default(0)
  geometry         Json
  geom             Unsupported("geometry(Point, 4326)")?
  address          String?
  condition        ShelterCondition
  status           ShelterStatus    @default(ACTIVE)
  facilities       String?
  officerId        Int?
  officer          User?            @relation(fields: [officerId], references: [id], onDelete: SetNull)
  evacuees         Evacuee[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Road {
  id              Int               @id @default(autoincrement())
  name            String
  geometry        Json
  geom            Unsupported("geometry(LineString, 4326)")?
  type            RoadType
  condition       RoadCondition
  vulnerability   RoadVulnerability
  length          Float?
  safe_cost       Float?
  cost            Float?
  length_m        Float?
  reverse_cost    Float?
  source          Int?
  target          Int?
  bpbdRiskLevel   BpbdRiskLevel?
  bpbdRiskScore   Float?
  combinedHazard  Float?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([bpbdRiskLevel])
}

model EvacuationRoute {
  id        Int       @id @default(autoincrement())
  name      String
  geometry  Json
  type      RouteType
  score     Float
  startLat  Float
  startLon  Float
  endLat    Float
  endLon    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PublicFacility {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  geometry  Json
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BpbdRiskZone {
  id          Int           @id @default(autoincrement())
  kecamatan   String
  desa        String
  name        String
  riskLevel   BpbdRiskLevel
  bahaya      String?
  iaGempa     Int?
  taGempa     Int?
  tRisk       Float?
  skorTRisk   Float?
  kodeDesa    Float?
  kodeKec     Int?
  geometry    Json
  geom        Unsupported("geometry(MultiPolygon, 4326)")?
  area        Float?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([riskLevel])
  @@index([kecamatan])
  @@index([desa])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShelterLog {
  id          Int      @id @default(autoincrement())
  shelterId   Int
  officerId   Int
  action      String
  changes     Json
  createdAt   DateTime @default(now())
}

model Evacuee {
  id               Int            @id @default(autoincrement())
  shelterId        Int
  shelter          Shelter        @relation(fields: [shelterId], references: [id], onDelete: Cascade)
  name             String
  nik              String?
  gender           EvacueeGender
  age              Int
  address          String?
  phone            String?
  familySize       Int            @default(1)
  specialNeeds     String?
  medicalCondition String?
  status           EvacueeStatus  @default(ACTIVE)
  checkInDate      DateTime       @default(now())
  checkOutDate     DateTime?
  notes            String?
  registeredBy     Int?
  registeredByUser User?          @relation(fields: [registeredBy], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([shelterId])
  @@index([status])
  @@index([nik])
}
