generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgrouting, postgis, uuid_ossp(map: "uuid-ossp")]
}
model User {
  id                 Int                @id @default(autoincrement())
  email              String             @unique
  password           String
  name               String
  role               UserRole           @default(USER)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  registeredEvacuees Evacuee[]
  pushSubscriptions  PushSubscription[]
  managedEvacuationLocations EvacuationLocation[]
}

model Earthquake {
  id          Int                      @id @default(autoincrement())
  bmkgId      String?                  @unique
  magnitude   Float
  depth       Float
  lat         Float
  lon         Float
  geom        Unsupported("geometry")?
  location    String
  region      String
  time        DateTime
  timestamp   DateTime                 @default(now())
  isLatest    Boolean                  @default(false)
  dirasakan   String?
  potential   String?
  shakemapUrl String?
}

model HazardZone {
  id          Int                      @id @default(autoincrement())
  name        String
  level       HazardLevel
  geometry    Json
  geom        Unsupported("geometry")?
  description String?
  area        Float?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model EvacuationLocation {
  id               Int                      @id @default(autoincrement())
  name             String
  category         EvacuationLocationCategory
  capacity         Int                      @default(0)
  currentOccupancy Int                      @default(0)
  geometry         Json
  geom             Unsupported("geometry")?
  address          String?
  condition        EvacuationLocationCondition
  status           EvacuationLocationStatus            @default(ACTIVE)
  facilities       String?
  officerId        Int?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  evacuees         Evacuee[]
  officer          User?                    @relation(fields: [officerId], references: [id])
}

model Road {
  id             Int                      @id @default(autoincrement())
  name           String
  geometry       Json
  geom           Unsupported("geometry")?
  type           RoadType
  condition      RoadCondition
  vulnerability  RoadVulnerability
  length         Float?
  safe_cost      Float?
  cost           Float?
  length_m       Float?
  reverse_cost   Float?
  source         Int?
  target         Int?
  bpbdRiskLevel  BpbdRiskLevel?
  bpbdRiskScore  Float?
  combinedHazard Float?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([bpbdRiskLevel])
}

model EvacuationRoute {
  id        Int       @id @default(autoincrement())
  name      String
  geometry  Json
  type      RouteType
  score     Float
  startLat  Float
  startLon  Float
  endLat    Float
  endLon    Float
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PublicFacility {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  geometry  Json
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BpbdRiskZone {
  id          Int                      @id @default(autoincrement())
  kecamatan   String
  desa        String
  name        String
  riskLevel   BpbdRiskLevel
  bahaya      String?
  iaGempa     Int?
  taGempa     Int?
  tRisk       Float?
  skorTRisk   Float?
  kodeDesa    Float?
  kodeKec     Int?
  geometry    Json
  geom        Unsupported("geometry")?
  area        Float?
  description String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([riskLevel])
  @@index([kecamatan])
  @@index([desa])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
}

model EvacuationLocationLog {
  id                   Int      @id @default(autoincrement())
  evacuationLocationId Int
  officerId            Int
  action               String
  changes              Json
  createdAt            DateTime @default(now())
}

model Evacuee {
  id                   Int           @id @default(autoincrement())
  evacuationLocationId Int
  name             String
  nik              String?
  gender           EvacueeGender
  age              Int
  address          String?
  phone            String?
  familySize       Int           @default(1)
  specialNeeds     String?
  medicalCondition String?
  status           EvacueeStatus @default(ACTIVE)
  checkInDate      DateTime      @default(now())
  checkOutDate     DateTime?
  notes            String?
  registeredBy     Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  registeredByUser   User?         @relation(fields: [registeredBy], references: [id])
  evacuationLocation EvacuationLocation       @relation(fields: [evacuationLocationId], references: [id], onDelete: Cascade)

  @@index([evacuationLocationId])
  @@index([status])
  @@index([nik])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum UserRole {
  ADMIN
  USER
  EVACUATION_LOCATION_OFFICER
}

enum HazardLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RoadType {
  NATIONAL
  PROVINCIAL
  REGIONAL
  LOCAL
}

enum RoadCondition {
  GOOD
  MODERATE
  POOR
  DAMAGED
}

enum RoadVulnerability {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EvacuationLocationCondition {
  GOOD
  MODERATE
  NEEDS_REPAIR
  DAMAGED
}

enum EvacuationLocationCategory {
  SCHOOL
  FIELD
  GOVERNMENT
}

enum EvacuationLocationStatus {
  ACTIVE
  STANDBY
  UNAVAILABLE
}

enum RouteType {
  PRIMARY
  ALTERNATIVE
}

enum BpbdRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum EvacueeStatus {
  ACTIVE
  RELOCATED
  RETURNED_HOME
}

enum EvacueeGender {
  MALE
  FEMALE
}
